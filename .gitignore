# ============================================================================
# SmartIoT .gitignore
# ⚠️  এই ফাইল delete করবেন না — secrets/keystore leak ঠেকাতে জরুরি
# ============================================================================

# ── Secrets & Credentials (CRITICAL — কখনো commit করবেন না) ────────────────
esp32/SmartIoT_v15/secrets.h
android/key.properties
*.jks
*.keystore
android/app/google-services.json
lib/firebase_options.dart

# ── Flutter / Dart ───────────────────────────────────────────────────────
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
build/
*.lock
!pubspec.lock

# ── Android ──────────────────────────────────────────────────────────────
android/local.properties
android/.gradle/
android/captures/
android/gradlew
android/gradlew.bat
*.iml
.gradle/

# ── iOS ──────────────────────────────────────────────────────────────────
ios/Flutter/Flutter.framework
ios/Flutter/Flutter.podspec
ios/Pods/
ios/.symlinks/
ios/Runner.xcworkspace/

# ── IDE ──────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
.DS_Store

# ── ESP32 / Arduino ──────────────────────────────────────────────────────
esp32/**/*.bin
esp32/**/build/

# ── Misc ─────────────────────────────────────────────────────────────────
*.log
coverage/
