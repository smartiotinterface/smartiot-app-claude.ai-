<?xml version="1.0" encoding="utf-8"?>
<!--
    Android 12+ (API 31+) Splash Screen
    Uses the new SplashScreen API — windowSplashScreenBackground sets the
    background colour shown before Flutter renders its own splash widget.
-->
<resources>
    <style name="LaunchTheme" parent="Theme.SplashScreen">
        <!-- Match your app's primary dark-blue brand colour -->
        <item name="windowSplashScreenBackground">#0D1B2A</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="postSplashScreenTheme">@style/NormalTheme</item>
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
    </style>

    <style name="NormalTheme" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:windowBackground">?android:colorBackground</item>
    </style>
</resources>
